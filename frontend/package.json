{
  "name": "robo4-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "TETROBOT - GUI-first modular robotics modeling and simulation platform",
  "author": "Nischay Sai <nischaysai35@gmail.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electron": "node electron/launch.cjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && node electron/launch.cjs\"",
    "electron:build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "dist": "vite build && electron-builder --dir",
    "icons": "node scripts/make-icons.cjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@huggingface/transformers": "^3.8.1",
    "occt-import-js": "^0.0.23",
    "postprocessing": "6.36.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.164.1",
    "uplot": "^1.6.32",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "vite": "^5.3.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.nischaysai.tetrobot",
    "productName": "TETROBOT-Demo-NischaySai",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NischaySai35",
        "repo": "robo4"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "TETROBOT",
      "runAfterFinish": true,
      "shortcutName": "TETROBOT-Demo-NischaySai",
      "artifactName": "TETROBOT-Demo-NischaySai-Setup-${version}.${ext}",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "uninstallDisplayName": "TETROBOT-Demo-NischaySai",
      "deleteAppDataOnUninstall": false
    }
  }
}
