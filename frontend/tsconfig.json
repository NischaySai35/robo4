{
  // Transitional config: the whole codebase is TS and typecheck is green here.
  // strict mode (incl. strictNullChecks) is ON and green. `noImplicitAny` is the
  // last relaxation — turning it on flags ~600 un-annotated params in the dynamic
  // viewport/AI/scripting glue (low-value `: any` busywork); enable when desired.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "release"]
}
